<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Becem Training{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚽</text></svg>">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        
        {# Run `composer require symfony/webpack-encore-bundle` to start using Symfony UX #}
        {% block stylesheets %}
            <link rel="preconnect" href="https://fonts.googleapis.com">
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
            <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
            <style>
                :root {
                    --primary: #2563eb;
                    --primary-hover: #1d4ed8;
                    --secondary: #64748b;
                    --accent: #f59e0b;
                    --dark: #0f172a;
                    --light: #f8fafc;
                    --glass: rgba(255, 255, 255, 0.8);
                }
                body {
                    font-family: 'Outfit', sans-serif;
                    background-color: #f1f5f9;
                    color: #334155;
                    overflow-x: hidden;
                }
                .navbar {
                    backdrop-filter: blur(10px);
                    background: var(--glass) !important;
                    border-bottom: 1px solid rgba(0,0,0,0.05);
                }
                .navbar-brand {
                    font-weight: 700;
                    letter-spacing: -0.5px;
                    color: var(--primary) !important;
                }
                .btn-primary {
                    background-color: var(--primary);
                    border-color: var(--primary);
                    font-weight: 600;
                    padding: 0.6rem 1.5rem;
                    border-radius: 8px;
                    transition: all 0.3s ease;
                }
                .btn-primary:hover {
                    background-color: var(--primary-hover);
                    transform: translateY(-2px);
                    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
                }
                .card-stats {
                    border-radius: 16px;
                    border: none;
                    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
                    transition: all 0.3s ease;
                }
                .card-stats:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
                }
                .notification-dropdown {
                    width: 350px;
                    max-height: 480px;
                    border-radius: 12px;
                    padding: 0;
                    overflow: hidden;
                    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
                    border: none;
                }
                .notification-item {
                    border-bottom: 1px solid #f1f5f9;
                    padding: 12px 16px;
                    transition: all 0.2s;
                    cursor: pointer;
                }
                .notification-item:hover {
                    background-color: #f8fafc;
                }
                .notification-item.unread {
                    background-color: #eff6ff;
                    border-left: 4px solid var(--primary);
                }
                .badge-notification {
                    position: absolute;
                    top: 2px;
                    right: 2px;
                    font-size: 0.65rem;
                    font-weight: 700;
                }
                .hero-section {
                    background: radial-gradient(circle at top left, #2563eb, #1e40af);
                    color: white;
                    padding: 120px 0;
                    position: relative;
                }
                .hero-section::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 100%;
                    height: 60px;
                    background: #f1f5f9;
                    clip-path: polygon(0 100%, 100% 100%, 100% 0);
                }
                .footer {
                    background-color: var(--dark);
                    color: rgba(255,255,255,0.6);
                    padding: 80px 0 40px;
                    margin-top: 100px;
                }
                .footer h5 { color: white; margin-bottom: 20px; }
                .footer a { color: rgba(255,255,255,0.6); transition: color 0.3s; text-decoration: none; }
                .footer a:hover { color: white; }
            </style>
        {% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                function markAsRead(id, element) {
                    fetch('/notifications/mark-as-read/' + id)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                element.closest('.notification-item').classList.remove('unread');
                                // Update badge count if exists
                                const badge = document.querySelector('.badge-notification');
                                if (badge) {
                                    let count = parseInt(badge.innerText);
                                    if (count > 1) {
                                        badge.innerText = count - 1;
                                    } else {
                                        badge.remove();
                                    }
                                }
                            }
                        });
                }
            </script>
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">BECEM</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home') }}">Home</a>
                        </li>
                        {% if is_granted('ROLE_USER') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_training_index') }}">Trainings</a>
                        </li>
                        {% endif %}
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        {% if app.user %}
                            {# Notifications Dropdown #}
                            {% set unreadNotifications = 0 %}
                            {% for n in app.user.notifications %}
                                {% if not n.isRead %}{% set unreadNotifications = unreadNotifications + 1 %}{% endif %}
                            {% endfor %}

                            <li class="nav-item dropdown me-2">
                                <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell fs-5"></i>
                                    {% if unreadNotifications > 0 %}
                                        <span class="badge rounded-pill bg-danger badge-notification">
                                            {{ unreadNotifications }}
                                        </span>
                                    {% endif %}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end notification-dropdown shadow border-0" aria-labelledby="notificationDropdown">
                                    <li class="p-2 border-bottom d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0 fw-bold">Notifications</h6>
                                        {% if unreadNotifications > 0 %}
                                            <a href="{{ path('app_notification_clear_all') }}" class="text-xs text-decoration-none">Mark all as read</a>
                                        {% endif %}
                                    </li>
                                    {% for notification in app.user.notifications|reverse %}
                                        <li class="notification-item {{ not notification.isRead ? 'unread' : '' }}">
                                            <div class="d-flex flex-column" onclick="markAsRead({{ notification.id }}, this)">
                                                <small class="text-muted mb-1">{{ notification.createdAt|date('d M, H:i') }}</small>
                                                <span class="small">{{ notification.message }}</span>
                                            </div>
                                        </li>
                                    {% else %}
                                        <li class="p-4 text-center text-muted">
                                            <i class="bi bi-bell-slash d-block fs-3 mb-2"></i>
                                            <span class="small">No notifications yet</span>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </li>

                            {% if is_granted('ROLE_COACH') %}
                            <li class="nav-item">
                                <a class="btn btn-outline-primary me-2" href="{{ path('app_admin_dashboard') }}">Dashboard</a>
                            </li>
                            {% endif %}
                            <li class="nav-item">
                                <span class="navbar-text me-3">Welcome, {{ app.user.firstName }}</span>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-danger" href="{{ path('app_logout') }}">Logout</a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="btn btn-primary" href="{{ path('app_login') }}">Login</a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="footer">
            <div class="container text-center">
                <p>&copy; 2024 Becem Training Management. Professional Football Solutions.</p>
                <div class="mt-3">
                    <a href="#" class="text-white me-3 text-decoration-none"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-white me-3 text-decoration-none"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="text-white text-decoration-none"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
        </footer>
    </body>
</html>
