{% extends 'backoffice/base.html.twig' %}

{% block title %}League Details{% endblock %}

{% block stylesheets %}
<style>
.detail-card {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
}

.detail-table {
    width: 100%;
}

.detail-table tr {
    border-bottom: 1px solid #f4f5f8;
}

.detail-table tr:last-child {
    border-bottom: none;
}

.detail-table th {
    padding: 15px 20px;
    background: #f8f9fa;
    font-weight: 600;
    color: #374151;
    width: 200px;
    font-size: 14px;
}

.detail-table td {
    padding: 15px 20px;
    color: #596882;
    font-size: 14px;
}

.btn-action {
    padding: 8px 16px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
    display: inline-block;
}

.btn-edit {
    background: rgba(1, 104, 250, 0.1);
    color: #0168fa;
}

.btn-edit:hover {
    background: #0168fa;
    color: #fff;
}

.badge-status {
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
}

.badge-active {
    background: rgba(16, 183, 89, 0.1);
    color: #10b759;
}

.badge-upcoming {
    background: rgba(244, 161, 0, 0.1);
    color: #f4a100;
}

.badge-ended {
    background: rgba(108, 117, 125, 0.1);
    color: #6c757d;
}
</style>
{% endblock %}

{% block content %}
<div class="az-content-body">
    {# Page Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">League Details</h2>
            <p class="text-muted mb-0">View league information</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_league_admin_index') }}" class="btn btn-secondary">
                <i class="typcn typcn-arrow-back"></i> Back to List
            </a>
            <a href="{{ path('app_league_admin_edit', {'id': league.id}) }}" class="btn-action btn-edit">
                <i class="typcn typcn-edit"></i> Edit
            </a>
        </div>
    </div>

    {# Details Card #}
    <div class="card">
        <div class="card-body p-0">
            <table class="detail-table">
                <tbody>
                    <tr>
                        <th>League ID</th>
                        <td><strong>#{{ league.id }}</strong></td>
                    </tr>
                    <tr>
                        <th>Name</th>
                        <td><strong>{{ league.name }}</strong></td>
                    </tr>
                    <tr>
                        <th>Game</th>
                        <td>{{ league.game }}</td>
                    </tr>
                    <tr>
                        <th>Start Date</th>
                        <td>{{ league.startDate ? league.startDate|date('F j, Y') : '-' }}</td>
                    </tr>
                    <tr>
                        <th>End Date</th>
                        <td>{{ league.endDate ? league.endDate|date('F j, Y') : '-' }}</td>
                    </tr>
                    <tr>
                        <th>Number of Teams</th>
                        <td>{{ league.numTeams }}</td>
                    </tr>
                    <tr>
                        <th>Format</th>
                        <td>{{ league.format }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            <span class="badge-status badge-{{ league.status == 'active' ? 'active' : (league.status == 'upcoming' ? 'upcoming' : 'ended') }}">
                                {{ league.status|upper }}
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Prize Pool</th>
                        <td><strong>${{ league.prizePool ? league.prizePool|number_format(2) : '0.00' }}</strong></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    {# Delete Section #}
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="text-danger mb-3">Danger Zone</h5>
            <p class="text-muted mb-3">Once you delete a league, there is no going back. Please be certain.</p>
            
            <form method="post" 
                  action="{{ path('app_league_admin_delete', {'id': league.id}) }}" 
                  onsubmit="return confirm('Are you sure you want to delete this league? This action cannot be undone.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ league.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="typcn typcn-trash"></i> Delete League
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
