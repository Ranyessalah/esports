{% extends 'backoffice/base.html.twig' %}

{% block title %}Leagues{% endblock %}

{% block stylesheets %}
<style>
.table { background:#fff; border-radius:8px; overflow:hidden; }
.table thead th { background:#f8f9fa; font-size:13px; text-transform:uppercase; color:#596882; font-weight:600; border-bottom:2px solid #e1e5eb; padding:12px 15px; }
.table tbody td { vertical-align:middle; padding:12px 15px; border-bottom:1px solid #f4f5f8; }
.table tbody tr:last-child td { border-bottom:none; }
.table tbody tr:hover { background:#f8f9fa; }
.btn-action { width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px; text-decoration:none; transition:all .2s; }
.btn-show  { background:rgba(16,183,89,.1); color:#10b759; }
.btn-show:hover  { background:#10b759; color:#fff; }
.btn-edit  { background:rgba(1,104,250,.1); color:#0168fa; }
.btn-edit:hover  { background:#0168fa; color:#fff; }
.btn-delete{ background:rgba(220,38,38,.1); color:#dc2626; }
.btn-delete:hover{ background:#dc2626; color:#fff; }
</style>
{% endblock %}

{% block content %}
<div class="az-content-body">
    {# Page Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Leagues</h2>
            <p class="text-muted mb-0">Manage your gaming leagues</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_league_admin_calendar') }}"   class="btn btn-outline-secondary"><i class="typcn typcn-calendar"></i> Calendar</a>
            <a href="{{ path('app_league_admin_statistics') }}" class="btn btn-outline-success"><i class="typcn typcn-chart-bar"></i> Statistics</a>
            <a href="{{ path('app_league_admin_export_pdf') }}" class="btn btn-outline-danger"><i class="typcn typcn-document-text"></i> Export PDF</a>
            <a href="{{ path('app_league_admin_new') }}"        class="btn btn-primary"><i class="typcn typcn-plus"></i> Add League</a>
        </div>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Search #}
    <form method="get" class="mb-3 d-flex gap-2">
        <input type="text" name="search" class="form-control" placeholder="Search by name, game or status…" value="{{ searchQuery }}">
        <button class="btn btn-outline-secondary">Search</button>
        {% if searchQuery %}<a href="{{ path('app_league_admin_index') }}" class="btn btn-outline-danger">Clear</a>{% endif %}
    </form>

    {# Table Card #}
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th><th>Name</th><th>Game</th><th>Start</th><th>End</th>
                            <th>Teams</th><th>Status</th><th>Prize Pool</th><th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for league in leagues %}
                        <tr>
                            <td><strong>#{{ league.id }}</strong></td>
                            <td>{{ league.name }}</td>
                            <td>{{ league.game }}</td>
                            <td>{{ league.startDate ? league.startDate|date('Y-m-d') : '-' }}</td>
                            <td>{{ league.endDate   ? league.endDate|date('Y-m-d')   : '-' }}</td>
                            <td>{{ league.numTeams }}</td>
                            <td>
                                <span class="badge bg-{{ league.status == 'active' ? 'success' : (league.status == 'upcoming' ? 'warning' : 'secondary') }}">
                                    {{ league.status }}
                                </span>
                            </td>
                            <td>${{ league.prizePool|number_format(2) }}</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn-action btn-show"   href="{{ path('app_league_admin_show',   {id:league.id}) }}" title="View"><i class="typcn typcn-eye"></i></a>
                                    <a class="btn-action btn-edit"   href="{{ path('app_league_admin_edit',   {id:league.id}) }}" title="Edit"><i class="typcn typcn-edit"></i></a>
                                    <form method="post" action="{{ path('app_league_admin_delete', {id:league.id}) }}" onsubmit="return confirm('Delete this league?');" style="display:inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~league.id) }}">
                                        <button class="btn-action btn-delete" title="Delete"><i class="typcn typcn-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="9" class="text-center py-4 text-muted">
                                <i class="typcn typcn-info-large" style="font-size:48px;opacity:.3;"></i>
                                <p class="mb-0 mt-2">No leagues found</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Pagination #}
    <div class="mt-3 d-flex justify-content-center">
        {{ knp_pagination_render(leagues) }}
    </div>
</div>
{% endblock %}
