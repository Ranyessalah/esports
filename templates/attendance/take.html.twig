{% extends 'admin_base.html.twig' %}

{% block title %}Take Attendance - {{ training.title }}{% endblock %}

{% block admin_content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">Attendance: {{ training.title }}</h1>
    <a href="{{ path('app_training_show', {id: training.id}) }}" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to Training
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="mb-0">Player Checklist - {{ training.date|date('Y-m-d') }}</h5>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 250px;">Player Name</th>
                            <th style="width: 200px;">Status</th>
                            <th>Comment</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for player in players %}
                            {% set currentAtt = attendanceMap[player.id] ?? null %}
                            <tr>
                                <td>
                                    <strong>{{ player.fullName }}</strong>
                                    {% if currentAtt and currentAtt.status == 'registered' %}
                                        <span class="badge bg-info text-dark ms-2"><i class="bi bi-star-fill"></i> Interested</span>
                                    {% endif %}
                                    <br>
                                    <small class="text-muted">{{ player.email }}</small>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <input type="radio" class="btn-check" name="attendance[{{ player.id }}][status]" id="p_{{ player.id }}" value="present" 
                                            {{ currentAtt and currentAtt.status == 'present' ? 'checked' : '' }} required>
                                        <label class="btn btn-outline-success btn-sm" for="p_{{ player.id }}">Present</label>

                                        <input type="radio" class="btn-check" name="attendance[{{ player.id }}][status]" id="a_{{ player.id }}" value="absent"
                                            {{ currentAtt and currentAtt.status == 'absent' ? 'checked' : '' }}>
                                        <label class="btn btn-outline-danger btn-sm" for="a_{{ player.id }}">Absent</label>
                                    </div>
                                </td>
                                <td>
                                    <input type="text" name="attendance[{{ player.id }}][comment]" class="form-control form-control-sm" 
                                        placeholder="Optional comment..." value="{{ currentAtt ? currentAtt.comment : '' }}">
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-5 text-muted">
                                    <i class="bi bi-people fs-2 d-block mb-3"></i>
                                    No players have registered for this session yet.<br>
                                    Attendance can only be taken for players who join via their dashboard.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if players %}
                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-primary px-5">
                        <i class="bi bi-check-circle me-1"></i> Save All Attendance
                    </button>
                </div>
            {% endif %}
        </form>
    </div>
</div>
{% endblock %}
