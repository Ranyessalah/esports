{% extends 'admin_base.html.twig' %}

{% block title %}Admin Dashboard - Becem{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-4 mb-4 border-bottom">
        <div>
            <h1 class="h2 fw-bold mb-0">Coach Command Center</h1>
            <p class="text-muted mb-0">Manage your sessions, players, and track attendance.</p>
        </div>
        <div class="btn-toolbar mb-2 mb-md-0">
            <a href="{{ path('app_training_new') }}" class="btn btn-primary shadow-sm hover-lift">
                <i class="bi bi-plus-lg me-2"></i> Create New Training
            </a>
        </div>
    </div>

    <!-- Quick Stats Hub -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card card-stats border-0 h-100 p-4 bg-white">
                <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                        <span class="text-muted text-uppercase fw-bold small">Total Volume</span>
                        <h2 class="display-6 fw-bold mb-0 mt-1">{{ totalTrainings }}</h2>
                        <p class="text-success small mb-0 mt-2"><i class="bi bi-arrow-up"></i> Lifetime Sessions</p>
                    </div>
                    <div class="icon-shape bg-soft-primary text-primary rounded-3 p-3 ms-3">
                        <i class="bi bi-calendar-event fs-2"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-stats border-0 h-100 p-4 bg-white">
                <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                        <span class="text-muted text-uppercase fw-bold small">Squad Size</span>
                        <h2 class="display-6 fw-bold mb-0 mt-1">{{ totalPlayers }}</h2>
                        <p class="text-primary small mb-0 mt-2"><i class="bi bi-people"></i> Registered Players</p>
                    </div>
                    <div class="icon-shape bg-soft-success text-success rounded-3 p-3 ms-3">
                        <i class="bi bi-people-fill fs-2"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-stats border-0 h-100 p-4 bg-white">
                <div class="d-flex align-items-start">
                    <div class="flex-grow-1">
                        <span class="text-muted text-uppercase fw-bold small">Active Runway</span>
                        <h2 class="display-6 fw-bold mb-0 mt-1">{{ upcomingCount }}</h2>
                        <p class="text-warning small mb-0 mt-2"><i class="bi bi-lightning-charge"></i> Upcoming Sessions</p>
                    </div>
                    <div class="icon-shape bg-soft-warning text-warning rounded-3 p-3 ms-3">
                        <i class="bi bi-stopwatch fs-2"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Trainings Section with Search and Filters -->
    <div class="card card-stats border-0 bg-white overflow-hidden">
        <div class="card-header bg-white py-4 px-4 border-0">
            <div class="row align-items-center">
                <div class="col-lg-4">
                    <h5 class="mb-0 fw-bold">Recent Session History</h5>
                </div>
                <div class="col-lg-8 text-lg-end mt-3 mt-lg-0">
                    <form action="{{ path('app_admin_dashboard') }}" method="get" class="row g-2 justify-content-lg-end">
                        <div class="col-auto">
                            <input type="text" name="search" class="form-control form-control-sm border-0 bg-light" placeholder="Search title..." value="{{ currentFilters.search }}">
                        </div>
                        <div class="col-auto">
                            <select name="theme" class="form-select form-select-sm border-0 bg-light">
                                <option value="">All Themes</option>
                                {% for theme in themes %}
                                    <option value="{{ theme }}" {{ currentFilters.theme == theme ? 'selected' : '' }}>{{ theme }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-sm btn-dark px-3">Filter</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="table-responsive p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="px-4 py-3">Training Information</th>
                        <th class="py-3">Schedule</th>
                        <th class="py-3">Location</th>
                        <th class="py-3 text-end px-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    {% for training in trainings %}
                        <tr>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar bg-soft-info p-2 rounded-circle me-3">
                                        <i class="bi bi-trophy text-info"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold fs-6">{{ training.title }}</div>
                                        <div class="badge bg-soft-primary text-primary rounded-pill small">{{ training.theme }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3">
                                <div class="fw-semibold">{{ training.date|date('M d, Y') }}</div>
                                <small class="text-muted">{{ training.startTime|date('H:i') }} - {{ training.endTime|date('H:i') }}</small>
                            </td>
                            <td class="py-3 text-secondary">
                                <i class="bi bi-geo-alt me-1"></i> {{ training.location }}
                            </td>
                            <td class="text-end px-4">
                                <div class="dropdown">
                                    <button class="btn btn-light btn-sm rounded-circle p-2" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0">
                                        <li><a class="dropdown-item py-2" href="{{ path('app_training_show', {'id': training.id}) }}"><i class="bi bi-eye me-2"></i> View Details</a></li>
                                        <li><a class="dropdown-item py-2" href="{{ path('app_training_edit', {'id': training.id}) }}"><i class="bi bi-pencil me-2 text-warning"></i> Edit Session</a></li>
                                        <li><a class="dropdown-item py-2" href="{{ path('app_admin_attendance_take', {'id': training.id}) }}"><i class="bi bi-check2-square me-2 text-success"></i> Mark Attendance</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" action="{{ path('app_training_delete', {'id': training.id}) }}" onsubmit="return confirm('Delete this session permanently?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training.id) }}">
                                                <button class="dropdown-item py-2 text-danger"><i class="bi bi-trash me-2"></i> Delete</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted italic">
                                <img src="https://illustrations.popsy.co/blue/sport-competition.svg" alt="Empty" style="width: 150px;" class="mb-3 opacity-50"><br>
                                No records found for current filters.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <style>
        .bg-soft-primary { background-color: #eff6ff !important; }
        .bg-soft-success { background-color: #f0fdf4 !important; }
        .bg-soft-warning { background-color: #fffbeb !important; }
        .bg-soft-info { background-color: #f0f9ff !important; }
        .icon-shape { width: 56px; height: 56px; display: flex; align-items: center; justify-content: center; }
        .avatar { width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; }
        .hover-lift { transition: transform 0.2s; }
        .hover-lift:hover { transform: translateY(-3px); }
    </style>
{% endblock %}
