{% extends 'admin_base.html.twig' %}

{% block title %}Edit Training - Becem{% endblock %}

{% block admin_content %}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-warning text-dark py-3 d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">Edit Training Session</h3>
                {{ include('training/_delete_form.html.twig') }}
            </div>
            <div class="card-body p-4">
                {{ include('training/_form.html.twig', {'button_label': 'Update Training'}) }}
                
                <div class="mt-4">
                    <a href="{{ path('app_training_index') }}" class="btn btn-outline-secondary">Back to list</a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
