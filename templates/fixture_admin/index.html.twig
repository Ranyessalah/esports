{% extends 'backoffice/base.html.twig' %}

{% block title %}Fixtures{% endblock %}

{% block stylesheets %}
<style>
.table { background:#fff; border-radius:8px; overflow:hidden; }
.table thead th { background:#f8f9fa; font-size:13px; text-transform:uppercase; color:#596882; font-weight:600; border-bottom:2px solid #e1e5eb; padding:12px 15px; }
.table tbody td { vertical-align:middle; padding:12px 15px; border-bottom:1px solid #f4f5f8; }
.table tbody tr:last-child td { border-bottom:none; }
.table tbody tr:hover { background:#f8f9fa; }
.btn-action  { width:32px; height:32px; display:inline-flex; align-items:center; justify-content:center; border-radius:4px; text-decoration:none; transition:all .2s; }
.btn-show    { background:rgba(16,183,89,.1); color:#10b759; }
.btn-show:hover   { background:#10b759; color:#fff; }
.btn-edit    { background:rgba(1,104,250,.1); color:#0168fa; }
.btn-edit:hover   { background:#0168fa; color:#fff; }
.btn-delete  { background:rgba(220,38,38,.1); color:#dc2626; }
.btn-delete:hover { background:#dc2626; color:#fff; }
</style>
{% endblock %}

{% block content %}
<div class="az-content-body">
    {# Page Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Fixtures</h2>
            <p class="text-muted mb-0">Manage game fixtures and matches</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_fixture_admin_calendar') }}"   class="btn btn-outline-secondary"><i class="typcn typcn-calendar"></i> Calendar</a>
            <a href="{{ path('app_fixture_admin_statistics') }}" class="btn btn-outline-success"><i class="typcn typcn-chart-bar"></i> Statistics</a>
            <a href="{{ path('app_fixture_admin_export_pdf') }}" class="btn btn-outline-danger"><i class="typcn typcn-document-text"></i> Export PDF</a>
            <a href="{{ path('app_fixture_admin_new') }}"        class="btn btn-primary"><i class="typcn typcn-plus"></i> Add Fixture</a>
        </div>
    </div>

    {# Flash messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Search #}
    <form method="get" class="mb-3 d-flex gap-2">
        <input type="text" name="search" class="form-control" placeholder="Search by status or round…" value="{{ searchQuery }}">
        <button class="btn btn-outline-secondary">Search</button>
        {% if searchQuery %}<a href="{{ path('app_fixture_admin_index') }}" class="btn btn-outline-danger">Clear</a>{% endif %}
    </form>

    {# Table #}
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th><th>Match Date</th><th>Status</th><th>Round</th><th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for fixture in fixtures %}
                        <tr>
                            <td><strong>#{{ fixture.id }}</strong></td>
                            <td>{{ fixture.matchDate ? fixture.matchDate|date('Y-m-d H:i') : '-' }}</td>
                            <td>
                                <span class="badge bg-{{ fixture.status == 'completed' ? 'success' : (fixture.status == 'live' ? 'danger' : 'secondary') }}">
                                    {{ fixture.status }}
                                </span>
                            </td>
                            <td>Round {{ fixture.round }}</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">
                                    <a class="btn-action btn-show" href="{{ path('app_fixture_admin_show', {id:fixture.id}) }}" title="View"><i class="typcn typcn-eye"></i></a>
                                    <a class="btn-action btn-edit" href="{{ path('app_fixture_admin_edit', {id:fixture.id}) }}" title="Edit"><i class="typcn typcn-edit"></i></a>
                                    <form method="post" action="{{ path('app_fixture_admin_delete', {id:fixture.id}) }}" onsubmit="return confirm('Delete this fixture?');" style="display:inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete'~fixture.id) }}">
                                        <button class="btn-action btn-delete" title="Delete"><i class="typcn typcn-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">
                                <i class="typcn typcn-info-large" style="font-size:48px;opacity:.3;"></i>
                                <p class="mb-0 mt-2">No fixtures found</p>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# Pagination #}
    <div class="mt-3 d-flex justify-content-center">
        {{ knp_pagination_render(fixtures) }}
    </div>
</div>
{% endblock %}
