{% extends 'backoffice/base.html.twig' %}

{% block title %}Fixtures{% endblock %}

{% block stylesheets %}
<style>
/* Table improvements */
.table {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
}

.table thead th {
    background: #f8f9fa;
    font-size: 13px;
    text-transform: uppercase;
    color: #596882;
    font-weight: 600;
    border-bottom: 2px solid #e1e5eb;
    padding: 12px 15px;
}

.table tbody td {
    vertical-align: middle;
    padding: 12px 15px;
    border-bottom: 1px solid #f4f5f8;
}

.table tbody tr:last-child td {
    border-bottom: none;
}

.table tbody tr:hover {
    background: #f8f9fa;
}

/* Action buttons */
.btn-action {
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
}

.btn-show {
    background: rgba(16, 183, 89, 0.1);
    color: #10b759;
}

.btn-show:hover {
    background: #10b759;
    color: #fff;
}

.btn-edit {
    background: rgba(1, 104, 250, 0.1);
    color: #0168fa;
}

.btn-edit:hover {
    background: #0168fa;
    color: #fff;
}

.btn-delete {
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
}

.btn-delete:hover {
    background: #dc2626;
    color: #fff;
}
</style>
{% endblock %}

{% block content %}
<div class="az-content-body">
    {# Page Header #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Fixtures</h2>
            <p class="text-muted mb-0">Manage game fixtures and matches</p>
        </div>
        <a href="{{ path('app_fixture_admin_new') }}" class="btn btn-primary">
            <i class="typcn typcn-plus"></i> Add Fixture
        </a>
    </div>

    {# Table Card #}
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Match Date</th>
                            <th>Status</th>
                            <th>Round</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for fixture in fixtures %}
                            <tr>
                                <td><strong>#{{ fixture.id }}</strong></td>
                                <td>{{ fixture.matchDate ? fixture.matchDate|date('Y-m-d H:i') : '-' }}</td>
                                <td>
                                    <span class="badge bg-{{ fixture.status == 'completed' ? 'success' : (fixture.status == 'live' ? 'danger' : 'secondary') }}">
                                        {{ fixture.status }}
                                    </span>
                                </td>
                                <td>Round {{ fixture.round }}</td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        <a class="btn-action btn-show" 
                                           href="{{ path('app_fixture_admin_show', {id: fixture.id}) }}"
                                           title="View">
                                            <i class="typcn typcn-eye"></i>
                                        </a>
                                        <a class="btn-action btn-edit" 
                                           href="{{ path('app_fixture_admin_edit', {id: fixture.id}) }}"
                                           title="Edit">
                                            <i class="typcn typcn-edit"></i>
                                        </a>
                                        <a class="btn-action btn-delete"
                                           href="{{ path('app_fixture_admin_delete', {id: fixture.id}) }}"
                                           onclick="return confirm('Are you sure you want to delete this fixture?');"
                                           title="Delete">
                                            <i class="typcn typcn-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">
                                    <i class="typcn typcn-info-large" style="font-size: 48px; opacity: 0.3;"></i>
                                    <p class="mb-0 mt-2">No fixtures found</p>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
