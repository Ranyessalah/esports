{% extends 'backoffice/base.html.twig' %}

{% block title %}Fixture Calendar{% endblock %}

{% block content %}
<div class="az-content-body">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Fixture Calendar</h2>
            <p class="text-muted mb-0">Visual schedule of all matches</p>
        </div>
        <a href="{{ path('app_fixture_admin_index') }}" class="btn btn-outline-secondary">
            <i class="typcn typcn-arrow-left"></i> Back to List
        </a>
    </div>

    {# Legend #}
    <div class="mb-3 d-flex gap-3 flex-wrap">
        <span><span style="display:inline-block;width:14px;height:14px;background:#10b759;border-radius:3px;margin-right:4px;"></span>Completed</span>
        <span><span style="display:inline-block;width:14px;height:14px;background:#ef4444;border-radius:3px;margin-right:4px;"></span>Live</span>
        <span><span style="display:inline-block;width:14px;height:14px;background:#6c757d;border-radius:3px;margin-right:4px;"></span>Scheduled</span>
    </div>

    <div class="card">
        <div class="card-body">
            <link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.3.0/main.min.css" rel="stylesheet">
            <div id="calendar"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.3.0/main.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    var calendarEl = document.getElementById('calendar');
    var calendar   = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        headerToolbar: {
            left:   'prev,next today',
            center: 'title',
            right:  'dayGridMonth,timeGridWeek,listMonth'
        },
        events: [
            {% for fixture in fixtures %}
            {
                title: 'Round {{ fixture.round }} — {{ fixture.status|capitalize }}',
                start: '{{ fixture.matchDate ? fixture.matchDate|date('Y-m-d') : '' }}T{{ fixture.matchDate ? fixture.matchDate|date('H:i:s') : '00:00:00' }}',
                url:   '{{ path('app_fixture_admin_show', {id: fixture.id}) }}',
                backgroundColor: '{{ fixture.status == "completed" ? "#10b759" : (fixture.status == "live" ? "#ef4444" : "#6c757d") }}',
                borderColor: 'transparent',
                extendedProps: { status: '{{ fixture.status }}', round: {{ fixture.round }} }
            },
            {% endfor %}
        ],
        eventClick: function(info) {
            if (info.event.url) {
                info.jsEvent.preventDefault();
                window.location.href = info.event.url;
            }
        },
        eventDidMount: function(info) {
            info.el.title = 'Round '+ info.event.extendedProps.round +'\nStatus: '+ info.event.extendedProps.status;
        }
    });
    calendar.render();
});
</script>
{% endblock %}
